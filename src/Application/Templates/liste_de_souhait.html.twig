<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ReadyToWork - Ma Liste de Souhaits</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap"
      rel="stylesheet"
    />

    <style>
      body {
        font-family: "Poppins", sans-serif;
        background:
          linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)),
          url("./image/panorama-lac-dallos-montagne-c-florianscala-1280x645-1734687992.jpg")
            no-repeat center center fixed;
        background-size: cover;
        color: white;
        min-height: 100vh;
      }

      /* Titre avec contour cyan (ton style original) */
      .titre_souhait {
        text-align: center;
        margin-top: 50px;
        margin-bottom: 50px;
        font-size: clamp(30px, 5vw, 50px); /* Responsive font size */
        font-weight: 800;
        color: white;
        -webkit-text-stroke-width: 2px;
        -webkit-text-stroke-color: rgb(26, 189, 230);
      }

      /* Style du tableau (ton style original adapté) */
      .tableau-container {
        background: rgba(0, 0, 0, 0.4);
        border-radius: 15px;
        padding: 20px;
        backdrop-filter: blur(5px);
      }

      .table-souhaits {
        border-collapse: collapse;
        width: 100%;
      }

      .table-souhaits th {
        padding-bottom: 15px;
        font-weight: bold;
        color: white;
        text-transform: uppercase;
        font-size: 0.9rem;
        text-align: center;
      }

      .table-souhaits td {
        border-top: 5px groove rgba(30, 171, 237, 0.721);
        border-bottom: 5px groove rgba(30, 171, 237, 0.721);
        min-width: 130px;
        text-align: center;
        padding: 20px;
        background: rgba(255, 255, 255, 0.05);
        transition: 0.3s;
      }

      .table-souhaits tr:hover td {
        background: rgba(30, 171, 237, 0.2);
        color: #ffcc00;
      }

      /* Barre de Recherche */
      .recherche-section {
        background: linear-gradient(
          to right,
          rgba(165, 143, 143, 0.8),
          rgba(128, 128, 223, 0.8)
        );
        padding: 20px;
        border-radius: 10px;
        margin-bottom: 40px;
      }

      .nav-link-custom {
        color: white;
        text-decoration: none;
        padding: 8px 15px;
        border-radius: 5px;
        transition: 0.3s;
      }
      .nav-link-custom:hover {
        background: rgba(255, 255, 255, 0.2);
        color: #ffcc00;
      }

      .glass {
        background: var(--glass);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 15px;
      }
      .hover-warning:hover {
        color: #ffcc00 !important;
      }
    </style>
  </head>
  <body>
    <header class="container py-3">
      <div class="d-flex justify-content-between align-items-center px-lg-5">
        <a
          href="/"
          class="glass d-flex align-items-center p-2 px-3 text-decoration-none text-white"
        >
          <img
            src="../image/ReadyToWork.png"
            alt="Logo"
            height="35"
            class="me-2"
          />
          <span class="fw-bold">ReadyToWork</span>
        </a>
        <a
          href="/role"
          class="glass d-flex align-items-center p-2 px-3 text-decoration-none text-white"
        >
          <img
            src="../image/image_reunion.avif"
            alt="Profil"
            class="rounded-circle me-2"
            width="30"
            height="30"
          />
          <span>Mon Profil</span>
        </a>
      </div>
      <h1 class="text-center mt-4 fw-bold display-4">ReadyToWork</h1>
    </header>

    <nav class="container my-3">
      <hr class="text-white" />
      <div class="d-flex flex-wrap justify-content-center gap-3">
        <a href="/stage" class="nav-link-custom"
          >Trouver mon stage</a
        >
        <a
          href="/entreprise"
          class="nav-link-custom"
          >Trouver une entreprise</a
        >
        <a
          href="/souhait"
          class="nav-link-custom border border-info"
          >Liste de souhaits</a
        >

        <a
          href="/gestion_etudiants"
          id="btn-ajout-etudiant"
          class="nav-link-custom bg-secondary d-none"
          >Gestion Étudiants</a
        >
        <a
          href="/gestion_pilotes"
          id="btn-ajout-pilote"
          class="nav-link-custom bg-secondary d-none"
          >Gestion Pilotes</a
        >

        <a
          href="/connexion"
          class="nav-link-custom bg-primary px-3"
          style="display: none"
          >Se connecter</a
        >
        <a href="#" id="btn-logout" class="nav-link-custom bg-danger d-none"
          >Déconnexion</a
        >
      </div>
      <hr class="text-white" />
    </nav>

    <div class="container mb-5">
      <div class="recherche-section shadow">
        <form class="row g-3 justify-content-center">
          <div class="col-md-6">
            <input
              type="text"
              class="form-control"
              placeholder="Rechercher par job, mot-clé ou entreprise"
            />
          </div>
          <div class="col-md-3">
            <input type="text" class="form-control" placeholder="Où" />
          </div>
          <div class="col-md-auto">
            <button class="btn btn-info text-white fw-bold px-4" type="submit">
              Rechercher
            </button>
          </div>
        </form>
      </div>
    </div>

    <main class="container mb-5">
      <h1 class="titre_souhait">⭐ Voici votre liste de souhaits</h1>

      <div class="tableau-container table-responsive shadow-lg">
        <table class="table-souhaits">
          <thead>
            <tr>
              <th>Nom entreprise</th>
              <th>Ville</th>
              <th>Date du stage</th>
              <th>Domaine</th>
              <th>Niveau d'étude</th>
              <th>Salaire</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Google</td>
              <td>Paris</td>
              <td>Juin 2026</td>
              <td>Informatique</td>
              <td>Bac +3</td>
              <td>1200€</td>
            </tr>
            <tr>
              <td>Tesla</td>
              <td>Berlin</td>
              <td>Septembre 2026</td>
              <td>Ingénierie</td>
              <td>Bac +5</td>
              <td>1500€</td>
            </tr>
          </tbody>
        </table>
      </div>
    </main>

    <footer class="bg-dark py-4 mt-auto">
      <div class="container text-center">
        <div class="d-flex justify-content-center gap-4 mb-2">
          <a
            href="/politique"
            class="text-white-50 text-decoration-none small hover-warning"
            >Politique de confidentialité</a
          >
          <a
            href="/mentions"
            class="text-white-50 text-decoration-none small hover-warning"
            >Mentions légales</a
          >
        </div>
        <p class="text-secondary small mb-0">
          &copy; 2026 ReadyToWork. Tous droits réservés.
        </p>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
