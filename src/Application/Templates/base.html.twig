<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
		<title>
			{% block title %}{% endblock %}
			ReadyToWork</title>
		<link rel="icon" type="image/png" href="./image/ReadyToWork.png">
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
		<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet"/>

		<style>

			{
				# pour afficher background et banniere #
			}

			body {
				font-family: "Poppins", sans-serif;
				background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url("/image/panorama-lac-dallos-montagne-c-florianscala-1280x645-1734687992.jpg") no-repeat center center fixed;
				background-size: cover;
				color: white;
				min-height: 100vh;
			}
			.hero-banner {
				height: 140px;
				background: url("/image/image_reunion.avif") center/cover;
				position: absolute;
				width: 100%;
				top: 0;
				z-index: -1;
				filter: brightness(0.6);
			}

			{
				# effet sur les boutons #
			}
			.glass {
				background: rgba(255, 255, 255, 0.1);
				backdrop-filter: blur(10px);
				border: 1px solid rgba(255, 255, 255, 0.2);
				border-radius: 15px;
			}
			.nav-link-custom {
				color: white;
				padding: 10px 20px;
				transition: 0.3s;
				border-radius: 10px;
				text-decoration: none;
			}

			{
				# mettre ecriture des liens en jaune #
			}
			.nav-link-custom:hover {
				background: rgba(119, 119, 119, 0.2);
				transform: translateY(-3px);
				color: #ffcc00;
			}
			.hover-warning:hover {
				color: #ffcc00 !important;
			}

			{
				# pour barre de recherche #
			}
			.recherche-container {
				background: linear-gradient(to bottom, rgb(165, 143, 143), rgb(128, 128, 223));
				padding: 40px 0;
				margin-top: 20px;
				border-radius: 10px;
			}
			.glass-input {
				background: rgba(254, 254, 254, 0.7) !important;
				border: 3px solid rgba(0, 0, 0, 0.3) !important;
				color: black !important;
			}
			.btn-recherche-custom {
				background: rgba(255, 255, 255, 0.6);
				border: 3px solid rgba(0, 0, 0, 0.4);
				font-weight: bold;
				transition: 0.3s;
			}
			.btn-recherche-custom:hover {
				background: rgba(255, 255, 255, 0.2);
				transform: translateY(-2px);
			}
		</style>
	</head>
	<body>
		<div class="hero-banner"></div>

		<header class="container-fluid py-3">
			<div class="d-flex justify-content-between align-items-center px-lg-5">
				<a href="/" class="glass d-flex align-items-center p-2 px-3 text-decoration-none text-white">
					<img src="./image/ReadyToWork.png" alt="Logo" height="35" class="me-2"/>
					<span class="fw-bold">ReadyToWork</span>
				</a>
				<a href="/role" class="glass d-flex align-items-center p-2 px-3 text-decoration-none text-white">
					<img src="image/image_reunion.avif" alt="Profil" class="rounded-circle me-2" width="30" height="30"/>
					<span>Mon Profil</span>
				</a>
			</div>
			<h1 class="text-center mt-5 fw-bold text-uppercase ls-5">
				ReadyToWork
			</h1>
		</header>

		<nav class="container-fluid px-lg-5">
			<hr class="border-2 opacity-50"/>
			<div class="d-flex flex-wrap justify-content-center gap-3 py-2">
				<a href="/stage" class="glass nav-link-custom">Stage</a>
				<a href="/entreprise" class="glass nav-link-custom">Entreprise</a>
				<a href="/souhait" class="glass nav-link-custom">Liste de souhaits</a>
				<a href="/gestion_etudiants" id="btn-ajout-etudiant" class="nav-link-custom bg-primary d-none">Gestion Étudiants</a>
				<a href="/creation_entreprise" id="btn-ajout-entreprise" class="nav-link-custom bg-warning d-none">Gestion Entreprise</a>
				<a href="/gestion_pilotes" id="btn-ajout-pilote" class="nav-link-custom bg-info d-none">Gestion Pilotes</a>
				<a href="/gestion_offres" id="btn-ajout-offres" class="nav-link-custom bg-dark d-none">Gestion Offres</a>
				<a href="/page_connexion" id="btn-login" class="glass nav-link-custom border-primary d-none">Se connecter</a>
				<a href="#" id="btn-logout" class="nav-link-custom bg-danger d-none">Déconnexion</a>
			</div>
			<hr class="border-2 opacity-50"/>
		</nav>
		<div class="container">
			<div class="recherche-container shadow">
				<form class="d-flex flex-wrap justify-content-center gap-3 px-3">
					<input type="text" class="form-control glass-input w-50" placeholder="Job, mot-clé ou entreprise"/>
					<input type="text" class="form-control glass-input w-25" placeholder="Où"/>
					<button class="btn btn-light border-info border-2 fw-bold px-4" type="submit">Rechercher</button>
				</form>
			</div>
		</div>

		{% block content %}{% endblock %}
		<footer class="glass mt-5 py-4">
			{% block footer %}
				<div class="container d-flex justify-content-center gap-4">
					<a href="/politique" class="text-white-50 text-decoration-none small hover-warning">Politique de confidentialité</a>
					<a href="/mentions" class="text-white-50 text-decoration-none small hover-warning">Mentions légales</a>
				</div>
				<div class="text-center">
					<p class="text-white-50 small mb-0">
						&copy; 2026 ReadyToWork. Tous droits réservés.
					</p>
				</div>
			{% endblock %}
		</footer>
		<script>
			// Ta logique JS reste la même, juste on adapte les classes d-none de Bootstrap
document.addEventListener("DOMContentLoaded", function () {
const userRole = localStorage.getItem("userRole");
const btnEtudiant = document.getElementById("btn-ajout-etudiant");
const btnPilote = document.getElementById("btn-ajout-pilote");
const btnLogin = document.getElementById("btn-login");
const btnLogout = document.getElementById("btn-logout");
if (userRole === "admin") {
document.getElementById("btn-ajout-etudiant").classList.remove("d-none");
document.getElementById("btn-ajout-pilote").classList.remove("d-none");
document.getElementById("btn-ajout-entreprise").classList.remove("d-none");
document.getElementById("btn-ajout-offres").classList.remove("d-none");
document.getElementById("btn-login").classList.add("d-none");
document.getElementById("btn-logout").classList.remove("d-none");
}
if (userRole === "pilote") {
document.getElementById("btn-ajout-etudiant").classList.remove("d-none");
document.getElementById("btn-ajout-entreprise").classList.remove("d-none");
document.getElementById("btn-ajout-offres").classList.remove("d-none");
document.getElementById("btn-login").classList.add("d-none");
document.getElementById("btn-logout").classList.remove("d-none");
}
if (userRole === "etudiant") {
document;
document.getElementById("btn-login").classList.add("d-none");
document.getElementById("btn-logout").classList.remove("d-none");
}
});
document.getElementById("btn-logout").onclick = () => {
localStorage.clear();
location.reload();
};
		</script>
	</body>
</html>
