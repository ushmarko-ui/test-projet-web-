<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Créer un compte - ReadyToWork</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)),
                        url("../image/panorama-lac-dallos-montagne-c-florianscala-1280x645-1734687992.jpg") no-repeat center center fixed;
            background-size: cover;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .glass-container {
            width: 100%;
            max-width: 400px;
            padding: 40px;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border-radius: 20px;
            border: 2px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5);
        }

        .logo-signup {
            width: 180px;
            display: block;
            margin: 0 auto 30px auto;
        }

        .input-glass {
            background: rgba(255, 255, 255, 0.2) !important;
            border: 1px solid rgba(255, 255, 255, 0.3) !important;
            color: white !important;
            border-radius: 8px;
            padding: 12px;
        }

        .input-glass::placeholder {
            color: rgba(255, 255, 255, 0.8);
        }

        /* On force le focus pour que l'input reste lisible */
        .input-glass:focus {
            background: rgba(255, 255, 255, 0.3) !important;
            box-shadow: none;
            border-color: #ffcc00 !important;
        }

        .btn-create-custom {
            width: 100%;
            padding: 12px;
            border-radius: 30px;
            border: none;
            background: white;
            color: #333;
            font-weight: bold;
            transition: 0.3s;
            margin-top: 10px;
        }

        .btn-create-custom:hover {
            background: #2563eb;
            color: white;
            transform: translateY(-2px);
        }

        .link-highlight {
            color: #ffcc00;
            text-decoration: none;
            font-weight: bold;
        }
        
        .link-highlight:hover {
            color: white;
            text-decoration: underline;
        }
    </style>
</head>
<body>

    <div class="container d-flex flex-column align-items-center py-5">
        <img src="../image/ReadyToWork.png" alt="logo" class="logo-signup">

        <div class="glass-container text-center">
            <h2 class="text-white mb-4 fw-bold">Créer votre compte</h2>
            
            <form id="signup-form">
                <div class="mb-3">
                    <input type="text" class="form-control input-glass" placeholder="Nom d'utilisateur" required>
                </div>

                <div class="mb-3">
                    <input type="email" class="form-control input-glass" placeholder="Adresse E-mail" required>
                </div>

                <div class="mb-4">
                    <input type="password" class="form-control input-glass" placeholder="Mot de passe" required>
                </div>

                <button type="submit" class="btn-create-custom shadow">Créer le compte</button>

                <p class="mt-4 text-white small mb-0">
                    Déjà un compte ? 
                    <a href="/page_connexion.html" class="link-highlight ms-1">Connectez-vous</a>
                </p>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>