<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
		<title>Gestion des Pilotes - ReadyToWork</title>

		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
		<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet"/>

		<style>
			body {
				font-family: "Poppins", sans-serif;
				background-color: #1a1a1a;
				color: white;
				padding: 30px;
			}

			h2 {
				font-weight: 600;
				margin-bottom: 30px;
				color: #72b1d5;
				border-left: 5px solid #72b1d5;
				padding-left: 15px;
			}

			/* Style des inputs mode sombre */
			.form-control-dark {
				background-color: #121212 !important;
				border: 1px solid #333 !important;
				color: #ccc !important;
				font-size: 0.9rem;
			}

			.form-control-dark:focus {
				border-color: #72b1d5 !important;
				box-shadow: 0 0 0 0.25rem rgba(114, 177, 213, 0.25);
			}

			/* Tableau personnalisé */
			.table-custom {
				background-color: #212121 !important;
				border: 1px solid #333;
			}

			.table-custom th {
				background-color: #2c2c2c !important;
				color: #888 !important;
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 1px;
				border-bottom: 2px solid #333;
			}

			.table-custom td {
				color: #ccc;
				vertical-align: middle;
				border-bottom: 1px solid #333;
				padding: 15px !important;
			}

			/* Boutons */
			.btn-add-custom {
				background-color: #4a4a4a;
				color: white;
				border: none;
				transition: 0.3s;
				font-size: 1.2rem;
			}

			.btn-add-custom:hover {
				background-color: #72b1d5;
				transform: scale(1.05);
			}

			.btn-delete {
				background: none;
				border: none;
				color: #ff4d4d;
				opacity: 0.6;
				transition: 0.3s;
				font-size: 1.1rem;
			}

			.btn-delete:hover {
				opacity: 1;
				transform: scale(1.2);
			}
			.glass {
				background: var(--glass);
				backdrop-filter: blur(10px);
				border: 1px solid rgba(255, 255, 255, 0.2);
				border-radius: 15px;
			}
			input::placeholder {
				color: white !important;
			}
		</style>
	</head>
	<body>
		<div class="container-fluid">
			<div class="d-flex justify-content-between align-items-center px-lg-5">
				<h2>Gestion des Pilotes</h2>
				<a href="/" class="glass d-inline-flex align-items-center p-2 px-3 text-decoration-none text-white mb-auto">
					<img src="./image/ReadyToWork.png" alt="Logo" height="35" class="me-2"/>
					<span class="fw-bold">ReadyToWork</span>
				</a>
			</div>
			<div class="row g-2 mb-4 align-items-center bg-dark p-3 rounded shadow border border-secondary border-opacity-10">
				<div class="col-auto">
					<button class="btn btn-add-custom px-4 fw-bold shadow-sm" id="add-pilote-btn">
						+
					</button>
				</div>
				<div class="col-md-2">
					<input type="text" id="pilote-id" class="form-control form-control-dark" placeholder="ID Pilote"/>
				</div>
				<div class="col-md-2">
					<input type="text" id="pilote-last" class="form-control form-control-dark" placeholder="Nom Complet"/>
				</div>
				<div class="col-md-2">
					<input type="text" id="pilote-first" class="form-control form-control-dark" placeholder="Prenom"/>
				</div>
				<div class="col-md-2">
					<input type="text" id="pilote-centre" class="form-control form-control-dark" placeholder="Centre / Ville"/>
				</div>
				<div class="col-md-2">
					<input type="email" id="pilote-email" class="form-control form-control-dark" placeholder="E-mail Professionnel"/>
				</div>
			</div>

			<div class="table-responsive rounded shadow">
				<table class="table table-dark table-hover mb-0 table-custom">
					<thead>
						<tr>
							<th class="text-center" style="width: 100px">Actions</th>
							<th>ID</th>
							<th>Nom Complet</th>
							<th>Prenom</th>
							<th>Centre / Ville</th>
							<th>E-mail</th>
						</tr>
					</thead>
					<tbody id="pilote-table-body">
						{% for pilote in pilotes %}
							<tr>
								<td class="text-center">
									<button class="btn-delete btn-supprimer">🗑️</button>
								</td>
								<td>{{ pilote.id }}</td>
								<td>{{ pilote.Nom }}</td>
								<td>{{ pilote.prenom }}</td>
								<td>{{ pilote.ville }}</td>
								<td>{{ pilote.email }}</td>
							</tr>
						{% endfor %}
					</tbody>
				</tbody>
			</table>
		</div>
	</body>
</html></div><script>
// Logique d'ajout dynamique
document.getElementById("add-pilote-btn").onclick = function () {
const id = document.getElementById("pilote-id").value;
const last = document.getElementById("pilote-last").value;
const first = document.getElementById("pilote-first").value;
const centre = document.getElementById("pilote-centre").value;
const email = document.getElementById("pilote-email").value;

if (id && name && email) {
const tbody = document.getElementById("pilote-table-body");
const row = tbody.insertRow();

row.innerHTML = `
                    <td class="text-center">
                        <button class="btn-delete btn-supprimer">🗑️</button>
                    </td>
                    <td>${id}</td>
                    <td>${last}</td>
                    <td>${first}</td>
                    <td>${centre}</td>
                    <td>${email}</td>
                `;

// Vider les champs après l'ajout
document.querySelectorAll(".row input.form-control").forEach((input) => (input.value = ""));
} else {
alert("Veuillez remplir au moins l'ID, le Nom et l'Email.");
}
};

// Logique de suppression déléguée
document.getElementById("pilote-table-body").addEventListener("click", function (e) {
const deleteBtn = e.target.closest(".btn-supprimer");
if (deleteBtn) {
if (confirm("Voulez-vous vraiment supprimer ce pilote ?")) {
const ligne = deleteBtn.closest("tr");
ligne.remove();
}
}
});</script><script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script></body></html>
