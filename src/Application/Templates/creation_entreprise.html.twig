<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
		<title>Gestion des Étudiants - Stage Explorer</title>

		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
		<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet"/>

		<style>
			body {
				font-family: "Poppins", sans-serif;
				background-color: #1a1a1a;
				color: white;
				padding: 30px;
			}

			h2 {
				font-weight: 600;
				margin-bottom: 30px;
				color: #72b1d5;
			}

			/* Style des inputs mode sombre */
			.form-control-dark {
				background-color: #121212 !important;
				border: 1px solid #333 !important;
				color: #ccc !important;
				font-size: 0.9rem;
			}

			.form-control-dark:focus {
				border-color: #72b1d5 !important;
				box-shadow: none;
			}

			/* Tableau personnalisé */
			.table-custom {
				background-color: #212121 !important;
				border: 1px solid #333;
			}

			.table-custom th {
				background-color: #2c2c2c !important;
				color: #888 !important;
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 1px;
				border-bottom: 2px solid #333;
			}

			.table-custom td {
				color: #ccc;
				vertical-align: middle;
				border-bottom: 1px solid #333;
			}

			/* Boutons */
			.btn-add-custom {
				background-color: #4a4a4a;
				color: white;
				border: none;
				transition: 0.3s;
			}

			.btn-add-custom:hover {
				background-color: #72b1d5;
				color: white;
			}

			.btn-delete {
				background: none;
				border: none;
				color: #ff4d4d;
				opacity: 0.6;
				transition: 0.3s;
				font-size: 1.1rem;
			}

			.btn-delete:hover {
				opacity: 1;
				transform: scale(1.2);
			}
			.glass {
				background: var(--glass);
				backdrop-filter: blur(10px);
				border: 1px solid rgba(255, 255, 255, 0.2);
				border-radius: 15px;
			}
			input::placeholder {
				color: white !important;
			}
		</style>
	</head>
	<body>
		<div class="container-fluid">
			<div class="d-flex justify-content-between align-items-center px-lg-5">
				<h2>Gestion des Étudiants</h2>
				<a href="/" class="glass d-inline-flex align-items-center p-2 px-3 text-decoration-none text-white mb-auto">
					<img src="./image/ReadyToWork.png" alt="Logo" height="35" class="me-2"/>
					<span class="fw-bold">ReadyToWork</span>
				</a>
			</div>
			<div class="row g-2 mb-4 align-items-center bg-dark p-3 rounded shadow-sm border border-secondary border-opacity-25">
				<div class="col-auto">
					<button class="btn btn-add-custom px-4 fw-bold" id="add-student-btn">
						+
					</button>
				</div>
				<div class="col">
					<input type="text" id="input-id" class="form-control form-control-dark" placeholder="ID"/>
				</div>
				<div class="col">
					<input type="text" id="input-fname" class="form-control form-control-dark" placeholder="Nom entreprise"/>
				</div>
				<div class="col">
					<input type="text" id="input-lname" class="form-control form-control-dark" placeholder="Domaine"/>
				</div>
				<div class="col">
					<input type="text" id="input-user" class="form-control form-control-dark" placeholder="Lieux"/>
				</div>
				<div class="col">
					<input type="email" id="input-email" class="form-control form-control-dark" placeholder="E-mail"/>
				</div>
			</div>

			<div class="table-responsive rounded shadow">
				<table class="table table-dark table-hover mb-0 table-custom">
					<thead>
						<tr>
							<th class="text-center">Actions</th>
							<th>ID</th>
							<th>Name</th>
							<th>Domain</th>
							<th>Username</th>
							<th>E-mail</th>
						</tr>
					</thead>
					<tbody id="table-body">
						{% for entreprise in entreprises %}
							<tr>
								<td class="text-center">
									<button class="btn-delete btn-supprimer">🗑️</button>
								</td>
								<td>{{ entreprise.id }}</td>
								<td>{{ entreprise.nom}}</td>
								<td>{{ entreprise.domaine }}</td>
								<td>{{ entreprise.lieu }}</td>
								<td>{{ entreprise.email }}</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</body>
	</body>
</html></div><script>
// Logique d'ajout
document.getElementById("add-student-btn").onclick = function () {
const inputs = {
id: document.getElementById("input-id").value,
fname: document.getElementById("input-fname").value,
lname: document.getElementById("input-lname").value,
user: document.getElementById("input-user").value,
email: document.getElementById("input-email").value
};

if (inputs.id && inputs.fname && inputs.lname) {
const tbody = document.getElementById("table-body");
const row = tbody.insertRow();

row.innerHTML = `
                    <td class="text-center">
                        <button class="btn-delete btn-supprimer">🗑️</button>
                    </td>
                    <td>${
inputs.id
}</td>
                    <td>${
inputs.fname
}</td>
                    <td>${
inputs.lname
}</td>
                    <td>${
inputs.user
}</td>
                    <td>${
inputs.email
}</td>
                `;

// Nettoyage des champs
document.querySelectorAll("input.form-control").forEach((i) => (i.value = ""));
} else {
alert("Veuillez remplir au moins l'ID, le Prénom et le Nom.");
}
};

// Logique de suppression
document.getElementById("table-body").addEventListener("click", function (e) {
const btn = e.target.closest(".btn-supprimer");
if (btn) {
if (confirm("Voulez-vous vraiment supprimer cet étudiant ?")) {
btn.closest("tr").remove();
}
}
});</script><script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script></body></html>
